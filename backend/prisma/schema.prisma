// Trade Journal domain model — a personal, single-user trading-journal dashboard.
// There is no authentication and no per-user ownership: the app holds one person's
// trading accounts and trades. See context/architecture.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TradeSide {
  LONG
  SHORT
  LIQUIDATION
}

enum TradeStatus {
  OPEN
  CLOSED
}

// ---------------------------------------------------------------------------
// Trading
// ---------------------------------------------------------------------------

model TradingAccount {
  id              String   @id @default(cuid())
  label           String
  accountNumber   String   @unique
  startingBalance Float    @default(0)
  currency        String   @default("USD")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trades Trade[]

  @@map("trading_accounts")
}

model Trade {
  id         String      @id @default(cuid())
  accountId  String
  symbol     String
  side       TradeSide
  size       String? // e.g. "1/1", "0.25/0.25" (requested/filled), free-form
  entryPrice Float?
  exitPrice  Float?
  grossPnl   Float       @default(0)
  netPnl     Float       @default(0)
  fees       Float       @default(0)
  openedAt   DateTime?
  closedAt   DateTime
  ticket     String?
  status     TradeStatus @default(CLOSED)
  createdAt  DateTime    @default(now())

  account TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // A broker ticket is unique within an account, so re-importing a CSV is idempotent.
  @@unique([accountId, ticket])
  @@index([accountId, closedAt])
  @@map("trades")
}
