# Backend (NestJS) environment — copy to backend/.env and fill in real values.
# backend/.env is gitignored. Never commit real secrets.

# PostgreSQL (Prisma). Adjust user/host/port/db to your local setup.
# URL-encode the password if it contains special characters.
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/pantrychef?schema=public"

# JWT secrets — use long random strings (e.g. `openssl rand -base64 48`)
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"

# Google Gemini — get a real key at https://aistudio.google.com/apikey (starts with "AIza...")
GEMINI_API_KEY="AIza..."

# Frontend origin for CORS
CORS_ORIGIN="http://localhost:3000"
