# Backend (NestJS) environment — copy to backend/.env and fill in real values.
# backend/.env is gitignored. Never commit real secrets.

NODE_ENV="development"

# PostgreSQL (Prisma). Adjust user/host/port/db to your local setup.
# URL-encode the password if it contains special characters.
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/trade_journal?schema=public"

# Frontend origin for CORS
CORS_ORIGIN="http://localhost:3000"

# API port
PORT="3001"
